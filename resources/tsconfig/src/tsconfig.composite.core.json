{
    "extends": "./tsconfig.single.json",
    "compilerOptions": {
        "composite": true, //                                           Enable constraints that allow a TypeScript project to be used with project references.
        "declarationMap": true, //                                      Create sourcemaps for d.ts files.
        "outDir": "../../../build/tsc/core", //                         Specify an output folder for all emitted files.
        "rootDir": "../../../src/core", //                              Specify the root folder within your source files.
        "tsBuildInfoFile": "../../../build/tsc/.tsbuildinfo.core", //   Specify the folder for .tsbuildinfo incremental compilation files.
        "types": [], //                                                 Specify type package names to be included without being referenced in a source file.
    },
    "include": [
        "../../../src/core/**/*.ts"
    ],
}
