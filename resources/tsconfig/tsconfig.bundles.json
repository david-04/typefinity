{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "lib": ["ES2022", "DOM"],
        "outDir": "../../build/tsc/bundles",
        "rootDir": "../../src/bundles",
        "tsBuildInfoFile": "../../build/tsc/.tsbuildinfo.bundles"
    },
    "references": [
        //
        { "path": "tsconfig.cli.json" },
        { "path": "tsconfig.core.json" },
        { "path": "tsconfig.web.json" }
    ],
    "include": [
        "../../src/bundles/*.ts",
        "../../src/bundles/**/*.ts",
        "../../src/cli/*.ts",
        "../../src/cli/**/*.ts",
        "../../src/core/*.ts",
        "../../src/core/**/*.ts",
        "../../src/web/*.ts",
        "../../src/web/**/*.ts"
    ]
}
