{
    "extends": "./.launchpad/tsconfig.default.json",
    "compilerOptions": {
        "composite": true,
        "lib": ["ES2022"],
        "outDir": "build/tsc",
        "rootDir": "src",
        "tsBuildInfoFile": "build/tsc/.tsbuildinfo"
    },
    "references": [
        { "path": "resources/tsconfig/tsconfig.core.json" },
        { "path": "resources/tsconfig/tsconfig.cli.json" },
        { "path": "resources/tsconfig/tsconfig.web.json" }
    ],
    "include": ["src/*.ts"]
}
