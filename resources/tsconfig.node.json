//----------------------------------------------------------------------------------------------------------------------
// src/node
//----------------------------------------------------------------------------------------------------------------------
{
    "extends": "./tsconfig.composite.json",
    "compilerOptions": {
        "outDir": "../build/tsc/node", //                       Specify an output folder for all emitted files.
        "rootDir": "../src/node", //                            Specify the root folder within your source files.
        "sourceRoot": "../src/node", //                         Specify the root path for debuggers to find the reference source code.
        "tsBuildInfoFile": "../build/tsc/node/.tsbuildinfo", // Specify the folder for .tsbuildinfo incremental compilation files.
        "types": ["node"], //                                   Specify type package names to be included without being referenced in a source file.
    },
    "references": [
        {
            "path": "./tsconfig.core.json"
        }
    ],
    "include": [
        "../src/node/**/*"
    ]
}
