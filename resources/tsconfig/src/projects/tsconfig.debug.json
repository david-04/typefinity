//----------------------------------------------------------------------------------------------------------------------
// src/debug.ts
//----------------------------------------------------------------------------------------------------------------------

{
    "extends": "../tsconfig.single-project.json",
    "compilerOptions": {
        "composite": true, //                                       Enable constraints that allow a TypeScript project to be used with project references.
        "declarationMap": true, //                                  Create sourcemaps for d.ts files.
        "outDir": "../../../../build/tsc", //                       Specify an output folder for all emitted files.
        "rootDir": "../../../../src", //                            Specify the root folder within your source files.
        "sourceRoot": "../../../../src", //                         Specify the root path for debuggers to find the reference source code.
        "tsBuildInfoFile": "../../../../build/tsc/.tsbuildinfo", // Specify the folder for .tsbuildinfo incremental compilation files.
        "types": ["node"], //                                       Specify type package names to be included without being referenced in a source file.
    },
    "references": [
        {
            "path": "./tsconfig.core.json"
        },
        {
            "path": "./tsconfig.node.json"
        },
        {
            "path": "./tsconfig.scripts.json"
        },
        {
            "path": "./tsconfig.web.json"
        },
    ],
    "include": [
        "../../../../src/*.ts"
    ],
}
