//----------------------------------------------------------------------------------------------------------------------
// src/scripts
//----------------------------------------------------------------------------------------------------------------------

{
    "extends": "../tsconfig.single-project.json",
    "compilerOptions": {
        "composite": true, //                                                Enable constraints that allow a TypeScript project to be used with project references.
        "declarationMap": true, //                                           Create sourcemaps for d.ts files.
        "outDir": "../../../../build/tsc/scripts", //                        Specify an output folder for all emitted files.
        "rootDir": "../../../../src/scripts", //                             Specify the root folder within your source files.
        "sourceRoot": "../../../../src/scripts", //                          Specify the root path for debuggers to find the reference source code.
        "tsBuildInfoFile": "../../../../build/tsc/scripts/.tsbuildinfo", //  Specify the folder for .tsbuildinfo incremental compilation files.
        "types": ["node"], //                                                Specify type package names to be included without being referenced in a source file.
    },
    "references": [
        {
            "path": "./tsconfig.core.json"
        },
        {
            "path": "./tsconfig.node.json"
        },
    ],
    "include": [
        "../../../../src/scripts/**/*"
    ],
}
